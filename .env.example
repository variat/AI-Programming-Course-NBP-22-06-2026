# Environment Variables
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and should never be committed

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# OpenRouter API key
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-from-openrouter

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Text model for chat, decision, and policy reasoning
# Examples: openai/gpt-5.4-mini, openai/gpt-5.4, anthropic/claude-sonnet-4.5
OPENROUTER_TEXT_MODEL=openai/gpt-5.4-mini

# Vision model for multimodal image analysis
# Example: openai/gpt-5.4
OPENROUTER_VISION_MODEL=openai/gpt-5.4-mini

# Backward-compatible fallback model for local development
# Used only when a split model variable is missing outside production.
OPENROUTER_MODEL=openai/gpt-5.4-mini

# ============================================================================
# Context7 MCP (optional — for docs-aware coding with agents)
# ============================================================================
# Get your key from: https://context7.com
CONTEXT7_API_KEY=ctx7sk-your-context7-api-key-here

# ============================================================================
# Application Configuration (depends on chosen stack — adjust during course)
# ============================================================================

# Server port
PORT=3000

# ============================================================================
# Notes
# ============================================================================
# 1. API Key Fallback:
#    - If OPENAI_API_KEY is set, it will be used
#    - If OPENAI_API_KEY is NOT set, OPENROUTER_API_KEY will be used
#
# 2. Cost Control:
#    - gpt-5.4-mini is recommended for cost-effective testing
#
# 3. For Production:
#    - Never commit .env file
#    - Use environment variables or secret management
#    - Rotate keys regularly
